# .clang-format

BasedOnStyle: Google
# Google默认为2 这里改为4更通用
IndentWidth: 4
TabWidth: 4
# 使用空格代替Tab 跨平台不容易出问题
UseTab: Never
# 每行字符数限制
ColumnLimit: 120
AllowShortFunctionsOnASingleLine: Inline
AllowShortIfStatementsOnASingleLine: true
# 大括号换行风格
BreakBeforeBraces: Allman
# 指针和引用符号
# left=int* ptr
# right=int *ptr
PointerAlignment: Left
SpacesInAngles: false
SpaceBeforeParens: ControlStatements
# 命名空间内缩进
NamespaceIndentation: All
# 自动排序include语句 有些依赖必须严格顺序否则会出错比如glad和glfw
SortIncludes: true
# regroup 并合并相同模块的include
IncludeBlocks: Regroup
IncludeCategories:
  # glad must always be first
  - Regex: '^<glad/'
    Priority: 1
  # glfw must come after glad
  - Regex: '^<GLFW/'
    Priority: 2
  # third party headers
  - Regex: '^<(vulkan|OpenGL/glm|imgui|spdlog)/'
    Priority: 3
  # system headers
  - Regex: '^<.*>'
    Priority: 4
  # other
  - Regex: '^".*"'
    Priority: 5

# 自动换行注释
ReflowComments: true
AlignConsecutiveAssignments: true
AlignConsecutiveDeclarations: true
DerivePointerAlignment: false
FixNamespaceComments: true
# 自动注释未封闭的命名空间
CommentPragmas: '^ IWYU pragma:'
# public/protected/private缩进
AccessModifierOffset: -4

# 宏定义体缩进
# None 永远顶格
# BeforeHash #include随代码块缩进
# AfterHash #跟关键字会分开
IndentPPDirectives: BeforeHash

# 宏内部是否缩进
IndentWrappedFunctionNames: false
# 多行宏的反斜杠对齐
AlignEscapedNewlines: Left
# 允许宏内保持结构
AllowShortBlocksOnASingleLine: Never
# 避免宏被自动压缩
AllowShortLambdasOnASingleLine: None
# 保持宏展开结构
KeepEmptyLinesAtTheStartOfBlocks: false

# 函数/类/struct 定义之间自动空一行
# Leave-保持原样
# Always-自动加空行
# Never-自动删除空行
SeparateDefinitionBlocks: Always